@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .kpi-card {
        border: none;
        border-radius: 16px;
        transition: 0.3s;
        background: #fff;
    }

        .kpi-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        }

    .kpi-icon {
        font-size: 2.5rem;
        opacity: 0.8;
    }

    .kpi-value {
        font-size: 28px;
        font-weight: 700;
    }

    .kpi-label {
        color: #6c757d;
        font-size: 14px;
    }
</style>

<div class="container-fluid">

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card kpi-card shadow-sm p-4">
                <div class="d-flex justify-content-between align-items-center">

                    <div>
                        <div class="kpi-label">Total Persons</div>
                        <div class="kpi-value">@ViewBag.TotalPersons</div>
                    </div>

                    <i class="bi bi-people kpi-icon text-primary"></i>

                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card kpi-card shadow-sm p-4">
                <div class="d-flex justify-content-between align-items-center">

                    <div>
                        <div class="kpi-label">Active Clients</div>
                        <div class="kpi-value">@ViewBag.ActiveClients</div>
                    </div>

                    <i class="bi bi-person-check kpi-icon text-success"></i>

                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card kpi-card shadow-sm p-4">
                <div class="d-flex justify-content-between align-items-center">

                    <div>
                        <div class="kpi-label">New Entries</div>
                        <div class="kpi-value">@ViewBag.NewEntries</div>
                    </div>

                    <i class="bi bi-plus-circle kpi-icon text-warning"></i>

                </div>
            </div>
        </div>

    </div>

</div>