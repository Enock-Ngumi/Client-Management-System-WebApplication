@model List<Client_Management_System.Models.Persons>

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="mb-0 fw-bold">Persons Management</h3>
            <small class="text-muted">Manage all registered persons</small>
        </div>

        <a asp-controller="Person" asp-action="Create"
           class="btn btn-primary btn-lg rounded-pill shadow-sm">
            <i class="bi bi-plus-circle"></i> Add Person
        </a>

    </div>

    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-4">

            <div class="table-responsive">

                <table id="personsTable"
                       class="table table-hover align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>DOB</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>

                                <td class="fw-semibold">@item.FirstName</td>
                                <td>@item.LastName</td>

                                <td>
                                    <span class="text-primary">@item.Email</span>
                                </td>

                                <td>@item.PhoneNumber</td>

                                <td>
                                    <span class="badge bg-light text-dark">
                                        @item.Dob.ToString("yyyy-MM-dd")
                                    </span>
                                </td>

                                <td class="text-center">

                                    <a asp-controller="Person"
                                       asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-warning rounded-pill me-2">
                                        ✏️ Edit
                                    </a>

                                    <button class="btn btn-sm btn-outline-danger rounded-pill delete-btn"
                                            data-id="@item.Id">
                                        🗑 Delete
                                    </button>

                                </td>

                            </tr>
                        }
                    </tbody>

                </table>

            </div>

        </div>
    </div>

    <form id="deleteForm" method="post"
          asp-controller="Person"
          asp-action="Delete">
        <input type="hidden" id="deleteId" name="id" />
    </form>

</div>
@section Scripts {
    <script>
        document.querySelectorAll(".delete-btn").forEach(btn => {
            btn.addEventListener("click", function () {

                if (confirm("Are you sure you want to delete this person?")) {
                    document.getElementById("deleteId").value = this.dataset.id;
                    document.getElementById("deleteForm").submit();
                }

            });
        });
    </script>
}