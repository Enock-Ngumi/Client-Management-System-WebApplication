@model List<Client_Management_System.Models.Persons>

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="mb-0 fw-bold">Persons Management</h3>
            <small class="text-muted">Manage all registered persons</small>
        </div>

        <a asp-controller="Person" asp-action="Create"
           class="btn btn-primary btn-lg rounded-pill shadow-sm">
            <i class="bi bi-plus-circle"></i> Add Person
        </a>

    </div>

    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-4">

            <div class="table-responsive">

                <table id="personsTable" class="table table-hover align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>DOB</th>
                            <th>Created Date</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <td class="fw-semibold">@item.FirstName</td>
                                    <td>@item.LastName</td>

                                    <td>
                                        <span class="text-primary">@item.Email</span>
                                    </td>

                                    <td>@item.PhoneNumber</td>

                                    <td>
                                        @(item.Dob?.ToString("dd MMM yyyy") ?? "-")
                                    </td>

                                    <td>
                                        @(item.CreatedDate?.ToString("dd MMM yyyy hh:mm tt") ?? "-")
                                    </td>

                                    <td class="text-center align-middle">

                                        <a asp-controller="Person"
                                           asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-warning rounded-pill me-2">
                                            Edit
                                        </a>

                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger rounded-pill delete-btn"
                                                data-id="@item.Id">
                                            Delete
                                        </button>

                                    </td>

                                </tr>
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>
    </div>

    <form id="deleteForm" method="post"
          asp-controller="Person"
          asp-action="Delete">
        @Html.AntiForgeryToken()
        <input type="hidden" id="deleteId" name="id" />
    </form>

</div>

@section Scripts {

    <script>
        $(document).ready(function () {

            $('#personsTable').DataTable({
                pageLength: 10,
                lengthMenu: [10, 25, 50, 100],
                responsive: true,
                autoWidth: false,
                ordering: true,
                searching: true,

                dom: 'Bfrtip',

                buttons: [
                    {
                        extend: 'excelHtml5',
                        text: 'Excel',
                        className: 'btn btn-success btn-sm'
                    },
                    {
                        extend: 'pdfHtml5',
                        text: 'PDF',
                        className: 'btn btn-danger btn-sm'
                    },
                    {
                        extend: 'print',
                        text: 'Print',
                        className: 'btn btn-primary btn-sm'
                    },
                    {
                        extend: 'colvis',
                        text: 'Columns',
                        className: 'btn btn-secondary btn-sm'
                    }
                ],

                language: {
                    search: "Search:",
                    lengthMenu: "Show _MENU_ records",
                    paginate: {
                        previous: "←",
                        next: "→"
                    }
                }
            });

        });
    </script>

}