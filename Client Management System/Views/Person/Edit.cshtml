@model Client_Management_System.Models.Persons

<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-header bg-primary text-white p-4 rounded-top-4">
                    <h4 class="mb-0 fw-bold">Edit Person</h4>
                    <small class="opacity-75">Update the person’s information below</small>
                </div>

                <div class="card-body p-4 p-md-5 bg-light">

                    <form asp-action="Edit" method="post">

                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">First Name</label>
                                <input asp-for="FirstName" class="form-control form-control-lg shadow-sm" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Last Name</label>
                                <input asp-for="LastName" class="form-control form-control-lg shadow-sm" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>

                        </div>

                        <div class="mt-3">
                            <label class="form-label fw-semibold">Email Address</label>
                            <input asp-for="Email" class="form-control form-control-lg shadow-sm" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mt-3">
                            <label class="form-label fw-semibold">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control form-control-lg shadow-sm" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="mt-3">
                            <label class="form-label fw-semibold">Date of Birth</label>
                            <input asp-for="Dob" type="date" class="form-control form-control-lg shadow-sm" />
                            <span asp-validation-for="Dob" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4 pt-3">

                            <a asp-controller="Person" asp-action="Index"
                               class="btn btn-outline-secondary btn-lg px-4 rounded-pill">
                                Back
                            </a>

                            <button type="submit"
                                    class="btn btn-success btn-lg px-5 rounded-pill shadow-sm">
                                Update Person
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}