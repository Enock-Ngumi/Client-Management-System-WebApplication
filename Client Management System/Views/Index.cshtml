@model List<Client_Management_System.Models.Persons>

<div class="container-fluid py-4">

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">

            <div>
                <h3 class="fw-bold mb-0">Persons Management</h3>
                <small class="text-muted">Manage all client records</small>
            </div>

            <a class="btn btn-primary rounded-pill px-4"
               asp-controller="Person"
               asp-action="Create">
                 Add Person
            </a>

        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info shadow-sm rounded-3">
            No records found.
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4">

            <div class="card-body">

                <div class="mb-3">
                    <input type="text"
                           id="searchBox"
                           class="form-control form-control-lg rounded-pill"
                           placeholder="Search persons..." />
                </div>

                <div class="table-responsive">

                    <table class="table table-hover align-middle" id="personsTable">

                        <thead class="table-dark">
                            <tr>
                                <th>First Name</th>
                                <th>Last Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>DOB</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td class="fw-semibold">@item.FirstName</td>
                                    <td>@item.LastName</td>
                                    <td>@item.Email</td>
                                    <td>@item.PhoneNumber</td>

                                    <td>
                                        <span class="badge bg-light text-dark">
                                            @(item.Dob?.ToString("dd MMM yyyy") ?? "-")
                                        </span>
                                    </td>

                                    <td class="text-center">

                                        <div class="btn-group">

                                            <a asp-controller="Person"
                                               asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-warning">
                                                Edit
                                            </a>

                                            <a asp-controller="Person"
                                               asp-action="Delete"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-danger">
                                                Delete
                                            </a>

                                        </div>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>
    }

</div>